---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { Button } from '@harlem-line-hustle/ui';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('posts', ({ data }) => !data.draft);
  return posts.map((post) => ({ params: { slug: post.slug }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await post.render();

function formatDate(date: Date) {
  return date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
}
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  currentPath="/blog"
>
  <!-- ── Post header ────────────────────────────────────────── -->
  <section class="post-header">
    <div class="container">
      <a href="/blog" class="back-link">← All posts</a>
      <div class="post-meta">
        <time class="post-date" datetime={post.data.date.toISOString()}>
          {formatDate(post.data.date)}
        </time>
        <div class="post-tags">
          {post.data.tags.map((tag: string) => <span class="tag">{tag}</span>)}
        </div>
      </div>
      <h1 class="post-title">{post.data.title}</h1>
      <p class="post-description">{post.data.description}</p>
    </div>
  </section>

  <!-- ── Post body ─────────────────────────────────────────── -->
  <article class="post-body">
    <div class="container">
      <div class="prose">
        <Content />
      </div>
    </div>
  </article>

  <!-- ── Footer nav ────────────────────────────────────────── -->
  <section class="post-footer">
    <div class="container">
      <hr class="divider" />
      <div class="post-footer-inner">
        <Button as="a" href="/blog" variant="ghost" size="sm">← Back to Blog</Button>
        <Button as="a" href="/contact" variant="ghost" size="sm">Get in Touch →</Button>
      </div>
    </div>
  </section>

  <style>
    /* ── Post header ──────────────────────────────────────────── */

    .post-header {
      padding: var(--space-20) 0 var(--space-12);
      border-bottom: var(--border);
    }

    .back-link {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-wide);
      color: var(--color-text-dim);
      text-decoration: none;
      margin-bottom: var(--space-8);
      transition: color 150ms ease;
    }

    .back-link:hover {
      color: var(--color-text-muted);
    }

    .post-meta {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      flex-wrap: wrap;
      margin-bottom: var(--space-6);
    }

    .post-date {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      letter-spacing: var(--tracking-wide);
      color: var(--color-text-dim);
    }

    .post-tags {
      display: flex;
      flex-wrap: wrap;
      gap: var(--space-2);
    }

    .post-title {
      font-family: var(--font-sans);
      font-size: clamp(var(--text-3xl), 5vw, var(--text-5xl));
      font-weight: 200;
      line-height: var(--leading-tight);
      letter-spacing: var(--tracking-tight);
      color: var(--color-text);
      text-shadow: var(--glow-text);
      margin: 0 0 var(--space-6);
    }

    .post-description {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 300;
      line-height: var(--leading-relaxed);
      color: var(--color-text-muted);
      margin: 0;
      max-width: 640px;
    }

    /* ── Post body ────────────────────────────────────────────── */

    .post-body {
      padding: var(--space-16) 0;
    }

    /* Prose: all Markdown output is scoped under .prose */

    .prose {
      max-width: 680px;
      font-family: var(--font-sans);
      font-size: var(--text-base);
      font-weight: 300;
      line-height: var(--leading-relaxed);
      color: var(--color-text-muted);
    }

    .prose :global(h2) {
      font-family: var(--font-sans);
      font-size: var(--text-2xl);
      font-weight: 300;
      letter-spacing: var(--tracking-tight);
      color: var(--color-text);
      text-shadow: var(--glow-text);
      margin: var(--space-12) 0 var(--space-5);
      line-height: var(--leading-snug);
    }

    .prose :global(h3) {
      font-family: var(--font-sans);
      font-size: var(--text-lg);
      font-weight: 400;
      letter-spacing: var(--tracking-wide);
      color: var(--color-primary-200);
      text-shadow: var(--glow-text);
      margin: var(--space-8) 0 var(--space-3);
    }

    .prose :global(p) {
      margin: 0 0 var(--space-5);
    }

    .prose :global(p:last-child) {
      margin-bottom: 0;
    }

    .prose :global(strong) {
      font-weight: 500;
      color: var(--color-text);
    }

    .prose :global(em) {
      font-style: italic;
      color: var(--color-text);
    }

    .prose :global(a) {
      color: var(--color-primary-300);
      text-decoration: underline;
      text-decoration-color: var(--color-primary-600);
      text-underline-offset: 3px;
      transition:
        color 150ms ease,
        text-decoration-color 150ms ease;
    }

    .prose :global(a:hover) {
      color: var(--color-primary-100);
      text-decoration-color: var(--color-primary-400);
    }

    .prose :global(ul),
    .prose :global(ol) {
      margin: 0 0 var(--space-5);
      padding-left: var(--space-6);
      display: flex;
      flex-direction: column;
      gap: var(--space-2);
    }

    .prose :global(li) {
      line-height: var(--leading-relaxed);
    }

    .prose :global(ul li::marker) {
      color: var(--color-primary-500);
    }

    .prose :global(ol li::marker) {
      color: var(--color-primary-500);
      font-family: var(--font-mono);
      font-size: var(--text-sm);
    }

    .prose :global(code) {
      font-family: var(--font-mono);
      font-size: 0.875em;
      color: var(--color-primary-200);
      background-color: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-sm);
      padding: 0.1em 0.4em;
    }

    .prose :global(pre) {
      background-color: var(--color-bg-elevated);
      border: 1px solid var(--color-border);
      border-radius: var(--radius-md);
      padding: var(--space-5);
      overflow-x: auto;
      margin: 0 0 var(--space-6);
    }

    .prose :global(pre code) {
      background: none;
      border: none;
      padding: 0;
      font-size: var(--text-sm);
      color: var(--color-primary-200);
    }

    .prose :global(blockquote) {
      border-left: 2px solid var(--color-primary-500);
      margin: 0 0 var(--space-6);
      padding: var(--space-3) 0 var(--space-3) var(--space-6);
      color: var(--color-text-muted);
      font-style: italic;
    }

    .prose :global(hr) {
      border: none;
      border-top: 1px solid var(--color-border);
      margin: var(--space-10) 0;
    }

    /* ── Post footer ──────────────────────────────────────────── */

    .post-footer {
      padding-bottom: var(--space-16);
    }

    .post-footer-inner {
      display: flex;
      align-items: center;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: var(--space-4);
      padding-top: var(--space-8);
    }
  </style>
</BaseLayout>
