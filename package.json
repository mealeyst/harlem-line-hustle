{
  "name": "harlem-line-hustle",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "devDependencies": {
    "@storybook/react-vite": "8.6.18",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1"
  },
  "scripts": {
    "dev:game": "npm run dev --workspace=apps/game",
    "dev:site": "npm run dev --workspace=apps/site",
    "build:site": "npm run build --workspace=apps/site",
    "storybook": "npm run storybook --workspace=packages/ui",
    "format": "prettier --write \"**/*.{ts,tsx,astro,css,json}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,astro,css,json}\""
  }
}
